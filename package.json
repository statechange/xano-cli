{
  "name": "@statechange/xano-cli",
  "version": "0.2.0",
  "description": "CLI for Xano workspace management, performance analysis, XanoScript generation, and operational insights via private APIs",
  "type": "module",
  "bin": {
    "sc-xano": "./dist/index.js"
  },
